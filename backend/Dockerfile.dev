FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache postgresql-client

ARG DIRECT_URL=postgresql://cinnamon:cinnamon_dev_password@postgres:5432/cinnamon
ENV DIRECT_URL=$DIRECT_URL

COPY package*.json ./
COPY prisma ./prisma/

RUN npm ci --legacy-peer-deps --ignore-scripts && npx prisma generate

COPY tsconfig.json ./
COPY prisma.config.ts ./
COPY src ./src
COPY scripts ./scripts

RUN mkdir -p /app/uploads /app/uploads/storage /app/logs

ENV NODE_ENV=development
ENV PORT=3000

EXPOSE 3000

COPY scripts/docker-entrypoint.dev.sh ./docker-entrypoint.dev.sh
RUN chmod +x ./docker-entrypoint.dev.sh

CMD ["./docker-entrypoint.dev.sh"]
