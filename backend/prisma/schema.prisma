generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
}

model User {
  id                   Int                  @id @default(autoincrement())
  email                String               @unique
  is_active            Boolean              @default(true)
  created_at           DateTime             @default(now()) @db.Timestamptz(3)
  updated_at           DateTime             @updatedAt @db.Timestamptz(3)
  name                 String
  password             String
  role                 UserRole             @default(CUSTOMER)
  profile_image        String?
  phone                String?
  shipping_city        String?
  shipping_postal_code String?
  shipping_province    String?
  shipping_street      String?
  cart                 Cart?
  orders               Orders[]
  sales                Sales[]
  passwordResetTokens  PasswordResetToken[]
  whatsAppSessions     WhatsAppSession[]

  @@index([is_active])
  @@index([role])
  @@index([created_at])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Categories {
  id         String         @id @default(cuid())
  title      String
  image      String?
  created_at DateTime       @default(now()) @db.Timestamptz(3)
  is_active  Boolean        @default(true)
  status     CategoryStatus @default(active)
  deleted_at DateTime?
  products   Products[]

  @@index([status, is_active])
  @@index([created_at])
  @@index([title])
  @@index([deleted_at])
}

model Products {
  id          String       @id @default(cuid())
  title       String
  price       Decimal      @default(0.00) @db.Decimal(12, 2)
  is_active   Boolean      @default(true)
  created_at  DateTime     @default(now()) @db.Timestamptz(3)
  images      Json         @default("[]")
  categoryId  String?
  tags        Json?        @default("[]")
  description String
  state       ProductState @default(active)
  stock       Int          @default(1)
  options     Json         @default("[]")
  deleted_at  DateTime?
  orderItems  OrderItems[]
  category    Categories?  @relation(fields: [categoryId], references: [id])
  sales       Sales[]      @relation("ProductsToSales")

  @@index([categoryId])
  @@index([categoryId, is_active])
  @@index([is_active, state])
  @@index([created_at])
  @@index([price])
  @@index([deleted_at])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Sales {
  id             String        @id @default(cuid())
  payment_method PaymentMethod
  source         SaleSource
  created_at     DateTime      @default(now()) @db.Timestamptz(3)
  userId         Int?
  total          Decimal       @default(0.00) @db.Decimal(12, 2)
  tax            Decimal       @default(0.00) @db.Decimal(12, 2)
  loadedManually Boolean       @default(false)
  manualProducts Json?         @default("[]")
  paymentMethods Json?         @default("[]")
  processed      Boolean       @default(false)
  declined       Boolean       @default(false)
  decline_reason String?
  items          Json          @default("[]")
  orders         Orders[]
  user           User?         @relation(fields: [userId], references: [id])
  products       Products[]    @relation("ProductsToSales")

  @@index([created_at])
  @@index([userId])
  @@index([source, created_at])
  @@index([payment_method, created_at])
}

model Cart {
  id     Int          @id @default(autoincrement())
  total  Decimal      @default(0.00) @db.Decimal(12, 2)
  userId Int          @unique
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  OrderItems[]

  @@index([userId])
}

model OrderItems {
  id                String   @id @default(cuid())
  productId         String
  quantity          Int      @default(1)
  price_has_changed Boolean  @default(false)
  cartId            Int
  selected_options  Json     @default("[]")
  cart              Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product           Products @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([cartId])
  @@index([productId])
}

model Orders {
  id                    String      @id @default(cuid())
  userId                Int?
  items                 Json        @default("[]")
  total                 Decimal     @default(0.00) @db.Decimal(12, 2)
  payment_method        String
  created_at            DateTime    @default(now()) @db.Timestamptz(3)
  buyer_email           String?
  buyer_name            String?
  saleId                String?
  transfer_receipt_path String?
  buyer_phone           String?
  subtotal              Decimal?    @default(0.00) @db.Decimal(12, 2)
  status                OrderStatus @default(PENDING)
  sale                  Sales?      @relation(fields: [saleId], references: [id])
  user                  User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([created_at])
  @@index([saleId])
  @@index([buyer_email])
  @@index([status])
}

model FAQ {
  id         String    @id @default(cuid())
  question   String
  answer     String
  position   Int       @default(0)
  is_active  Boolean   @default(true)
  deleted_at DateTime?
  created_at DateTime  @default(now()) @db.Timestamptz(3)
  updated_at DateTime  @updatedAt @db.Timestamptz(3)

  @@index([is_active, position])
  @@index([deleted_at])
  @@index([created_at])
}

model BusinessData {
  id                         String             @id @default(cuid())
  name                       String
  email                      String
  phone                      String
  address                    String
  city                       String
  state                      String
  description                String?
  business_image             String?
  favicon                    String?
  type                       String?
  whatsapp_access_token      String?
  whatsapp_api_key           String?
  whatsapp_connected         Boolean            @default(false)
  whatsapp_enabled           Boolean            @default(false)
  whatsapp_phone_number      String?
  whatsapp_session_id        Int?
  whatsapp_webhook_secret    String?
  whatsapp_allowed_remitents String?
  hero_image                 String?
  active_palette             String             @default("kuromi")
  banner_config              Json?
  bankData                   BusinessBankData[]
}

model BusinessBankData {
  id             String       @id @default(cuid())
  bank_name      String
  account_number String
  account_holder String
  alias          String?
  cbu            String?
  businessId     String
  business       BusinessData @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model WhatsAppSession {
  phone           String    @id
  userId          Int
  state           String
  productData     Json      @default("{}")
  messageHistory  Json      @default("[]")
  lastActivity    DateTime  @default(now())
  lastUserMessage DateTime?
  reminderSent    Boolean   @default(false)
  reminderSentAt  DateTime?
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([lastActivity])
}

model ProcessedMessage {
  id         String   @id
  created_at DateTime @default(now())

  @@index([created_at])
}

model WhatsAppAlbumBuffer {
  id         String   @id @default(cuid())
  phone      String
  albumId    String
  data       Json
  updated_at DateTime @updatedAt

  @@unique([phone, albumId])
}

enum ProductState {
  active
  inactive
  draft
  out_stock
  deleted
}

enum CategoryStatus {
  deleted
  active
  inactive
}

enum SaleSource {
  WEB
  CAJA
}

enum PaymentMethod {
  TARJETA
  EFECTIVO
  QR
  NINGUNO
  TRANSFERENCIA
}
